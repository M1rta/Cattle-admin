{
  "version": "2",
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "scripts": {
    "dev": "python api/index.py"
  },
  "dependencies": {
    "mongodb": "^7.1.1"
  }
}